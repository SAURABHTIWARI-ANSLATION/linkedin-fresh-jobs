{
  "manifest_version": 3,
  "name": "LinkedIn Fresh Jobs Intelligence",
  "version": "1.0.0",
  "description": "Real-time job freshness filtering for LinkedIn Jobs. Filter by posted time and see what's new at a glance.",
  "permissions": [
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://www.linkedin.com/jobs/*"
  ],
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/*"
      ],
      "js": [
        "utils/constants.js",
        "utils/logger.js",
        "utils/helpers.js",
        "utils/storage.js",
        "content/parser.js",
        "content/filters.js",
        "content/scanner.js",
        "content/observers.js",
        "content/ui.js",
        "content/dashboard.js",
        "content/content.js"
      ],
      "css": [
        "content/styles.css"
      ],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "LinkedIn Fresh Jobs Intelligence"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "assets/*"
      ],
      "matches": [
        "https://www.linkedin.com/jobs/*"
      ]
    }
  ]
}
